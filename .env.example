# ─── Database ──────────────────────────────────────────────────────────────
POSTGRES_USER=stapel
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── App ───────────────────────────────────────────────────────────────────
SECRET_KEY=change_me_to_a_long_random_string
JWT_SECRET_KEY=change_me_to_another_long_random_string
ALLOWED_HOSTS=localhost
SITE_URL=http://localhost

# ─── Email ─────────────────────────────────────────────────────────────────
DEFAULT_FROM_EMAIL=Stapel Example <hello@example.com>
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# ─── OAuth (optional) ───────────────────────────────────────────────────────
GOOGLE_OAUTH2_KEY=
GOOGLE_OAUTH2_SECRET=

# ─── Admin suite (docs/admin-suite.md) ──────────────────────────────────────
# Dev on: let any staff user *view* the ops journals (outbox/taskstore/
# eventstore/StripeWebhookEvent…) — they stay read-only. Off (the prod default)
# hides them from everyone but a superuser. The only env-readable admin-suite
# knob; roles/backends are wired in core/settings/base.py.
SHOW_OPS_MODELS=true
# Cross-service nav ("Services ▾" menu). A monolith is one implicit service, so
# leave this empty — the "All Services" section collapses and the block still
# shows Swagger/Admin/Tools. In a microservices split each service ships the
# same list (stapel-new-service appends a row). Extra tool/monitoring links go
# through STAPEL_ADMIN["NAV_LINKS"] in settings, not here.
STAPEL_SERVICES=

# ─── Run command ────────────────────────────────────────────────────────────
RUN_CMD=gunicorn core.wsgi:application --bind 0.0.0.0:8000 --workers 2
